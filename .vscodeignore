# Build artifacts
dist/
*.vsix

# Tests and test data
tests/
src/**/*.test.js
coverage/

# Config files not needed in extension
vitest.config.js
.eslintrc*

# Docs that don't need to ship
VISION.md
PENDING.md

# Claude Code settings
.claude/

# Scripts for local dev only
scripts/

# IDE / OS
.vscode/
.DS_Store

# Assets — only icon.png and sidebar.svg are needed by the extension
assets/screenshots/
assets/icons/icon.svg
assets/icons/README.md

# Git
gitignore
